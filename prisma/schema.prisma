generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TripMemberRole {
  OWNER
  PARTNER
}

enum TripStatus {
  PLANNING
  UPCOMING
  ACTIVE
  PAST
}

enum EventCategory {
  FLIGHT
  LODGING
  ACTIVITY
  FOOD
  TRANSPORT
}

enum ExpenseCategory {
  FLIGHT
  LODGING
  FOOD
  ACTIVITY
  TRANSPORT
  SHOPPING
  OTHER
}

model User {
  id            String       @id @db.Uuid
  email         String       @unique
  displayName   String?
  createdTrips  Trip[]       @relation("TripCreator")
  memberships   TripMember[]
  uploadedPhotos TripPhoto[]
  paidExpenses   TripExpense[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("users")
}

model Trip {
  id             String           @id @default(cuid())
  name           String
  destinations   String[]         @default([])
  startDate      DateTime?
  endDate        DateTime?
  coverPhotoUrl  String?
  coverPhotoPath String?
  budgetAmount   Decimal?         @db.Decimal(12, 2)
  currency       String           @default("USD")
  status         TripStatus       @default(PLANNING)
  inviteCode     String           @unique
  createdById    String           @db.Uuid
  createdBy      User             @relation("TripCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members        TripMember[]
  days           TripDay[]
  events         ItineraryEvent[]
  photos         TripPhoto[]
  expenses       TripExpense[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("trips")
}

model TripMember {
  id        String         @id @default(cuid())
  tripId    String
  userId    String         @db.Uuid
  role      TripMemberRole @default(PARTNER)
  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([tripId, userId])
  @@map("trip_members")
}

model TripDay {
  id        String           @id @default(cuid())
  tripId    String
  date      DateTime
  dayNumber Int
  trip      Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  events    ItineraryEvent[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([tripId, date])
  @@unique([tripId, dayNumber])
  @@map("trip_days")
}

model ItineraryEvent {
  id           String        @id @default(cuid())
  tripId       String
  dayId        String
  title        String
  category     EventCategory
  startTime    DateTime?
  endTime      DateTime?
  locationName String?
  latitude     Float?
  longitude    Float?
  notes        String?
  sortOrder    Int           @default(0)
  trip         Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day          TripDay       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tripId, dayId, sortOrder])
  @@map("itinerary_events")
}

model TripPhoto {
  id         String   @id @default(cuid())
  tripId     String
  uploaderId String   @db.Uuid
  storagePath String  @unique
  fileName   String
  caption    String?
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tripId, createdAt])
  @@map("trip_photos")
}

model TripExpense {
  id          String          @id @default(cuid())
  tripId      String
  payerId     String          @db.Uuid
  title       String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  expenseDate DateTime
  notes       String?
  trip        Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payer       User            @relation(fields: [payerId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tripId, expenseDate])
  @@index([payerId])
  @@map("trip_expenses")
}
